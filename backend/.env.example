# Railway runtime
NODE_ENV=production
PORT=8787
PUBLIC_BACKEND_URL=https://your-service.up.railway.app
PUBLIC_APP_URL=https://your-frontend.example.com
ALLOWED_ORIGINS=https://your-frontend.example.com
HOSTINGER_FRONTEND_URL=https://your-frontend.example.com

# PocketBase (backend only)
POCKETBASE_URL=https://your-pocketbase.example.com
PB_ADMIN_EMAIL=replace-with-pocketbase-superuser-email
PB_ADMIN_PASSWORD=replace-with-pocketbase-superuser-password
OWNER_EMAIL=replace-with-owner-email

# Required in production: generate a long independent random value
TOKEN_ENC_KEY=replace-with-long-random-encryption-key

# Deriv
DERIV_APP_ID=1089
DERIV_OAUTH_URL=https://oauth.deriv.com/oauth2/authorize?app_id=1089
DERIV_OAUTH_REDIRECT=https://your-frontend.example.com/deriv-callback.html
DERIV_AFFILIATE_LINK=https://your-deriv-affiliate-link.example.com

# OpenAI-compatible AI provider (backend only)
AI_PROVIDER=openai
AI_API_KEY=replace-with-provider-api-key
AI_MODEL=openai-t1-sg
AI_BASE_URL=https://api.freemodel.dev
# Optional full endpoint override; otherwise /v1/chat/completions is appended.
AI_ENDPOINT=
AI_TIMEOUT_MS=12000
AI_ADVISOR_CACHE_MS=30000

# Telegram (backend only)
TELEGRAM_BOT_TOKEN=replace-with-bot-token
TELEGRAM_WEBHOOK_SECRET=replace-with-random-webhook-secret
TELEGRAM_BOT_USERNAME=Apexrebornbot
TELEGRAM_BOT_URL=https://t.me/Apexrebornbot
TELEGRAM_USE_POLLING=false
TELEGRAM_CHANNEL_URL=https://t.me/your-channel
TELEGRAM_GROUP_URL=https://t.me/your-group
TELEGRAM_SUPPORT_URL=https://t.me/your-support-bot
TELEGRAM_ADMIN_CONTACT=@your-support-handle
# Backend-only numeric Telegram account that receives operational alerts.
TELEGRAM_ADMIN_ID=123456789
# Optional. Leave blank when membership is not required.
TELEGRAM_REQUIRED_CHANNEL_ID=
TELEGRAM_REQUIRED_GROUP_ID=

# Email and payments (backend only)
RESEND_API_KEY=replace-with-resend-key
RESEND_FROM_NAME=ApexBot
RESEND_FROM_EMAIL=no-reply@your-verified-domain.example
PAYMENT_PROVIDER=pluggable
PAYMENT_WEBHOOK_SECRET=replace-with-webhook-secret
